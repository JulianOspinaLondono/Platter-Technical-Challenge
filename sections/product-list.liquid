{% liquid
  assign max_items = section.settings.max_products
  assign mobile_show_more = section.settings.mobile_show_more
  assign mobile_visible = section.settings.mobile_visible_products | default: 4
  assign mobile_columns = section.settings.mobile_columns | default: '2'
  assign has_mobile_grid = false
  if mobile_show_more and section.settings.layout_type == 'carousel'
    assign has_mobile_grid = true
  endif
%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  data-testid="product-list"
  class="
    section
    section--{{ section.settings.section_width }}
    color-{{ section.settings.color_scheme }}
    section-resource-list
    spacing-style
    gap-style
  "
  style="
    {% render 'spacing-style', settings: section.settings %}
    {% render 'gap-style', value: section.settings.gap %}
  "
>
  <div class="section-resource-list__header">
    {%- content_for 'block', type: '_product-list-content', id: 'static-header' -%}
  </div>

  {% capture list_items %}
    {% if section.settings.collection != blank and shop.products_count != 0 %}
      {% paginate section.settings.collection.products by max_items %}
        {% for product in section.settings.collection.products limit: max_items %}
          <div
            class="resource-list__item"
          >
            {% # theme-check-disable UniqueStaticBlockId %}
              {% content_for 'block', type: '_product-card', id: 'static-product-card', closest.product: product %}
            {% # theme-check-enable UniqueStaticBlockId %}
          </div>

          {% unless forloop.last %}
            <!--@list/split-->
          {% endunless %}
        {% endfor %}
      {% endpaginate %}
    {% else %}
      {% for i in (1..max_items) %}
        <div
          class="resource-list__item"
        >
          {% # theme-check-disable UniqueStaticBlockId %}
            {% content_for 'block', type: '_product-card', id: 'static-product-card', closest.product: null %}
          {% # theme-check-enable UniqueStaticBlockId %}
        </div>

        {% unless forloop.last %}
          <!--@list/split-->
        {% endunless %}
      {% endfor %}
    {% endif %}
  {% endcapture %}

  {% liquid
    # Create an array from the list items to be used for different layout types
    assign list_items_array = list_items | strip | split: '<!--@list/split-->'
  %}

  {%- comment -%} Desktop: normal resource-list (carousel/grid/editorial) {%- endcomment -%}
  <div class="{% if has_mobile_grid %}hidden--mobile{% endif %}">
    {% render 'resource-list',
      list_items: list_items,
      list_items_array: list_items_array,
      settings: section.settings,
      slide_count: max_items,
      content_type: 'products',
      test_id: 'resource-list-grid'
    %}
  </div>

  {%- if section.settings.show_scrollbar and section.settings.layout_type == 'carousel' -%}
    <div class="product-list-scrollbar" id="scrollbar-{{ section.id }}" aria-hidden="true">
      <div class="product-list-scrollbar__track">
        <div class="product-list-scrollbar__thumb" id="scrollbar-thumb-{{ section.id }}"></div>
      </div>
    </div>
  {%- endif -%}

  {%- comment -%} Mobile: grid with Show More {%- endcomment -%}
  {%- if has_mobile_grid -%}
    <div class="product-list-mobile-grid hidden--desktop" id="mobile-grid-{{ section.id }}"
      style="
        --mobile-grid-columns: {{ mobile_columns }};
        --mobile-grid-gap: {{ section.settings.columns_gap | default: 8 }}px;
        --mobile-grid-row-gap: {{ section.settings.rows_gap | default: 24 }}px;
      "
    >
      <div class="product-list-mobile-grid__items">
        {%- for item in list_items_array -%}
          <div class="product-list-mobile-grid__item{% if forloop.index > mobile_visible %} product-list-mobile-grid__item--hidden{% endif %}"
            {% if forloop.index > mobile_visible %}data-mobile-hidden{% endif %}
          >
            {{ item }}
          </div>
        {%- endfor -%}
      </div>

      {%- if list_items_array.size > mobile_visible -%}
        <div class="product-list-mobile-grid__show-more">
          <button
            type="button"
            class="product-list-mobile-grid__btn"
            id="mobile-show-more-{{ section.id }}"
            aria-expanded="false"
            aria-controls="mobile-grid-{{ section.id }}"
          >
            {{ section.settings.show_more_text | default: 'Show More' }}
          </button>
        </div>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div
    class="section-resource-list__content"
    style="--horizontal-alignment: {{ section.settings.horizontal_alignment }};"
  >
    {%- content_for 'blocks' -%}
  </div>
</div>

{%- if section.settings.show_scrollbar and section.settings.layout_type == 'carousel' -%}
  <script>
    (function() {
      var sectionId = '{{ section.id }}';

      function initScrollbar() {
        var section = document.getElementById('scrollbar-' + sectionId);
        if (!section) return;

        var thumb = document.getElementById('scrollbar-thumb-' + sectionId);
        var sectionEl = section.closest('.section-resource-list');
        if (!sectionEl) return;

        var scroller = sectionEl.querySelector('slideshow-slides');
        if (!scroller) return;

        function updateThumb() {
          var scrollWidth = scroller.scrollWidth - scroller.clientWidth;
          if (scrollWidth <= 0) {
            section.style.display = 'none';
            return;
          }
          section.style.display = '';
          var ratio = scroller.clientWidth / scroller.scrollWidth;
          var progress = scroller.scrollLeft / scrollWidth;
          var trackWidth = section.querySelector('.product-list-scrollbar__track').offsetWidth;
          var thumbWidth = Math.max(ratio * trackWidth, 48);
          thumb.style.width = thumbWidth + 'px';
          thumb.style.transform = 'translateX(' + (progress * (trackWidth - thumbWidth)) + 'px)';
        }

        scroller.addEventListener('scroll', updateThumb, { passive: true });
        window.addEventListener('resize', updateThumb, { passive: true });

        /* Drag the thumb to scroll */
        var isDragging = false;
        var startX = 0;
        var startScrollLeft = 0;

        thumb.addEventListener('pointerdown', function(e) {
          isDragging = true;
          startX = e.clientX;
          startScrollLeft = scroller.scrollLeft;
          thumb.setPointerCapture(e.pointerId);
          scroller.style.scrollSnapType = 'none';
          scroller.style.scrollBehavior = 'auto';
          thumb.style.transition = 'none';
          e.preventDefault();
        });

        document.addEventListener('pointermove', function(e) {
          if (!isDragging) return;
          var trackWidth = section.querySelector('.product-list-scrollbar__track').offsetWidth;
          var thumbWidth = thumb.offsetWidth;
          var maxThumbTravel = trackWidth - thumbWidth;
          var scrollWidth = scroller.scrollWidth - scroller.clientWidth;
          var deltaX = e.clientX - startX;
          var scrollDelta = (deltaX / maxThumbTravel) * scrollWidth;
          scroller.scrollLeft = startScrollLeft + scrollDelta;
        });

        document.addEventListener('pointerup', function() {
          if (!isDragging) return;
          isDragging = false;
          scroller.style.scrollSnapType = '';
          scroller.style.scrollBehavior = '';
          thumb.style.transition = '';
        });

        /* Click on track to jump */
        section.querySelector('.product-list-scrollbar__track').addEventListener('click', function(e) {
          if (e.target === thumb) return;
          var rect = this.getBoundingClientRect();
          var clickPos = (e.clientX - rect.left) / rect.width;
          var scrollWidth = scroller.scrollWidth - scroller.clientWidth;
          scroller.scrollTo({ left: clickPos * scrollWidth, behavior: 'smooth' });
        });

        /* Initial state with delay to wait for layout */
        setTimeout(updateThumb, 100);

        /* MutationObserver in case slideshow loads lazily */
        var observer = new MutationObserver(updateThumb);
        observer.observe(scroller, { childList: true, subtree: true });
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initScrollbar);
      } else {
        initScrollbar();
      }
    })();
  </script>
{%- endif -%}

{% style %}
  .product-list-scrollbar {
    width: 100%;
    padding-top: 1.5rem;
    display: none;
  }

  @media screen and (min-width: 750px) {
    .product-list-scrollbar {
      display: block;
    }
  }

  .product-list-scrollbar__track {
    position: relative;
    width: 100%;
    height: 0.125rem;
    background: var(--color-border, #e5e5e5);
    border-radius: 0.125rem;
    cursor: pointer;
    transition: height 0.3s ease;
  }

  .product-list-scrollbar:hover .product-list-scrollbar__track,
  .product-list-scrollbar:active .product-list-scrollbar__track {
    height: 0.375rem;
  }

  .product-list-scrollbar__thumb {
    position: absolute;
    top: 50%;
    left: 0;
    height: 0.1875rem;
    min-width: 3rem;
    background: var(--color-foreground, #1a1a1a);
    border-radius: 0.1875rem;
    transform: translateY(-50%);
    cursor: grab;
    transition: height 0.3s ease;
    will-change: transform, width;
  }

  /* Larger hit area for easier grabbing */
  .product-list-scrollbar__thumb::before {
    content: '';
    position: absolute;
    top: -0.75rem;
    bottom: -0.75rem;
    left: 0;
    right: 0;
  }

  .product-list-scrollbar:hover .product-list-scrollbar__thumb,
  .product-list-scrollbar:active .product-list-scrollbar__thumb {
    height: 0.375rem;
  }

  .product-list-scrollbar__thumb:active {
    cursor: grabbing;
  }

  /* ===== Mobile Grid with Show More ===== */
  .product-list-mobile-grid__items {
    display: grid;
    grid-template-columns: repeat(var(--mobile-grid-columns, 2), 1fr);
    gap: var(--mobile-grid-row-gap, 1.5rem) var(--mobile-grid-gap, 0.5rem);
  }

  .product-list-mobile-grid__item {
    min-width: 0;
  }

  .product-list-mobile-grid__item--hidden {
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    visibility: hidden;
    transition:
      max-height 0.5s cubic-bezier(0.4, 0, 0.2, 1),
      opacity 0.4s ease 0.1s,
      visibility 0s linear 0.5s;
  }

  .product-list-mobile-grid__item--visible {
    max-height: 62.5rem;
    opacity: 1;
    overflow: visible;
    visibility: visible;
    transition:
      max-height 0.5s cubic-bezier(0.4, 0, 0.2, 1),
      opacity 0.4s ease 0.1s,
      visibility 0s linear 0s;
  }

  .product-list-mobile-grid__show-more {
    display: flex;
    justify-content: center;
    padding-top: 1.5rem;
  }

  .product-list-mobile-grid__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    max-width: 20rem;
    padding: 0.875rem 2rem;
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    background: var(--color-foreground, #1a1a1a);
    color: var(--color-background, #fff);
    border: none;
    border-radius: 3.125rem;
    cursor: pointer;
    transition: opacity 0.2s ease, transform 0.15s ease;
  }

  .product-list-mobile-grid__btn:hover {
    opacity: 0.85;
  }

  .product-list-mobile-grid__btn:active {
    transform: scale(0.98);
  }
{% endstyle %}

{%- if has_mobile_grid -%}
  <script>
    (function() {
      var sectionId = '{{ section.id }}';
      var showMoreText = {{ section.settings.show_more_text | default: 'Show More' | json }};
      var showLessText = {{ section.settings.show_less_text | default: 'Show Less' | json }};

      function initShowMore() {
        var btn = document.getElementById('mobile-show-more-' + sectionId);
        if (!btn) return;

        var grid = document.getElementById('mobile-grid-' + sectionId);
        var hiddenItems = grid.querySelectorAll('[data-mobile-hidden]');

        btn.addEventListener('click', function() {
          var isExpanded = btn.getAttribute('aria-expanded') === 'true';

          if (!isExpanded) {
            hiddenItems.forEach(function(item, index) {
              setTimeout(function() {
                item.classList.add('product-list-mobile-grid__item--visible');
              }, index * 60);
            });
            btn.setAttribute('aria-expanded', 'true');
            btn.textContent = showLessText;
          } else {
            /* Scroll to top of section before collapsing */
            var sectionTop = grid.closest('.section-resource-list');
            if (sectionTop) {
              sectionTop.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }

            setTimeout(function() {
              hiddenItems.forEach(function(item) {
                item.classList.remove('product-list-mobile-grid__item--visible');
              });
              btn.setAttribute('aria-expanded', 'false');
              btn.textContent = showMoreText;
            }, 300);
          }
        });
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initShowMore);
      } else {
        initShowMore();
      }
    })();
  </script>
{%- endif -%}

{% schema %}
{
  "name": "t:names.product_list",
  "class": "ui-test-product-list",
  "blocks": [
    {
      "type": "@theme"
    },
    {
      "type": "@app"
    },
    {
      "type": "_divider"
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "t:settings.collection"
    },
    {
      "type": "select",
      "id": "layout_type",
      "label": "t:settings.layout_type",
      "options": [
        {
          "value": "grid",
          "label": "t:options.grid"
        },
        {
          "value": "carousel",
          "label": "t:options.carousel"
        },
        {
          "value": "editorial",
          "label": "t:options.editorial"
        }
      ],
      "default": "grid"
    },
    {
      "type": "checkbox",
      "id": "carousel_on_mobile",
      "label": "t:settings.carousel_on_mobile",
      "default": false,
      "visible_if": "{{ section.settings.layout_type != 'carousel' }}"
    },
    {
      "type": "checkbox",
      "id": "show_scrollbar",
      "label": "Show scroll progress bar",
      "info": "Displays a draggable scrollbar below the carousel on desktop",
      "default": false,
      "visible_if": "{{ section.settings.layout_type == 'carousel' }}"
    },
    {
      "type": "header",
      "content": "Mobile: Show More",
      "visible_if": "{{ section.settings.layout_type == 'carousel' }}"
    },
    {
      "type": "checkbox",
      "id": "mobile_show_more",
      "label": "Enable grid with Show More on mobile",
      "info": "Replaces the carousel on mobile with a grid and a 'Show More' button",
      "default": false,
      "visible_if": "{{ section.settings.layout_type == 'carousel' }}"
    },
    {
      "type": "range",
      "id": "mobile_visible_products",
      "label": "Products visible on mobile",
      "info": "Products shown before tapping 'Show More'",
      "min": 2,
      "max": 12,
      "step": 2,
      "default": 4,
      "visible_if": "{{ section.settings.mobile_show_more == true }}"
    },
    {
      "type": "text",
      "id": "show_more_text",
      "label": "Show more button text",
      "default": "Show More",
      "visible_if": "{{ section.settings.mobile_show_more == true }}"
    },
    {
      "type": "text",
      "id": "show_less_text",
      "label": "Show less button text",
      "default": "Show Less",
      "visible_if": "{{ section.settings.mobile_show_more == true }}"
    },
    {
      "type": "range",
      "id": "max_products",
      "label": "t:settings.product_count",
      "min": 1,
      "max": 16,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "columns",
      "label": "t:settings.columns",
      "min": 1,
      "max": 8,
      "step": 1,
      "default": 4,
      "visible_if": "{{ section.settings.layout_type != 'editorial' }}"
    },
    {
      "type": "select",
      "id": "mobile_columns",
      "label": "t:settings.mobile_columns",
      "options": [
        {
          "value": "1",
          "label": "t:options.one_number"
        },
        {
          "value": "2",
          "label": "t:options.two_number"
        }
      ],
      "default": "2",
      "visible_if": "{{ section.settings.layout_type == 'grid' and section.settings.carousel_on_mobile == false }}"
    },
    {
      "type": "select",
      "id": "mobile_card_size",
      "label": "t:settings.mobile_columns",
      "options": [
        {
          "value": "60cqw",
          "label": "t:options.one_number"
        },
        {
          "value": "44cqw",
          "label": "t:options.two_number"
        }
      ],
      "default": "60cqw",
      "visible_if": "{{ section.settings.layout_type == 'carousel' or section.settings.carousel_on_mobile == true }}"
    },
    {
      "type": "range",
      "id": "columns_gap",
      "label": "t:settings.horizontal_gap",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 8,
      "visible_if": "{{ section.settings.layout_type == 'grid' or section.settings.layout_type == 'carousel' }}"
    },
    {
      "type": "range",
      "id": "rows_gap",
      "label": "t:settings.vertical_gap",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 8,
      "visible_if": "{{ section.settings.layout_type == 'grid'}}"
    },
    {
      "type": "header",
      "content": "t:content.carousel_navigation",
      "visible_if": "{{ section.settings.layout_type == 'carousel' or section.settings.carousel_on_mobile == true }}"
    },
    {
      "type": "select",
      "id": "icons_style",
      "label": "t:settings.icon",
      "options": [
        {
          "value": "arrow",
          "label": "t:options.arrows"
        },
        {
          "value": "chevron",
          "label": "t:options.chevrons"
        },
        {
          "value": "arrows_large",
          "label": "t:options.arrows_large"
        },
        {
          "value": "chevron_large",
          "label": "t:options.chevron_large"
        },
        {
          "value": "none",
          "label": "t:options.none"
        }
      ],
      "default": "arrow",
      "visible_if": "{{ section.settings.layout_type == 'carousel' or section.settings.carousel_on_mobile == true }}"
    },
    {
      "type": "select",
      "id": "icons_shape",
      "label": "t:settings.icon_background",
      "options": [
        {
          "value": "none",
          "label": "t:options.none"
        },
        {
          "value": "circle",
          "label": "t:options.circle"
        },
        {
          "value": "square",
          "label": "t:options.square"
        }
      ],
      "default": "none",
      "visible_if": "{{ section.settings.icons_style != 'none' and section.settings.layout_type == 'carousel' or section.settings.carousel_on_mobile == true }}"
    },
    {
      "type": "header",
      "content": "t:content.section_layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.width",
      "options": [
        {
          "value": "page-width",
          "label": "t:options.page"
        },
        {
          "value": "full-width",
          "label": "t:options.full"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "select",
      "id": "horizontal_alignment",
      "label": "t:settings.alignment",
      "options": [
        {
          "value": "flex-start",
          "label": "t:options.left"
        },
        {
          "value": "center",
          "label": "t:options.center"
        },
        {
          "value": "flex-end",
          "label": "t:options.right"
        }
      ],
      "default": "flex-start"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "t:settings.gap",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "t:names.products_grid",
      "category": "t:categories.products",
      "settings": {
        "collection": "",
        "max_products": 8,
        "layout_type": "grid",
        "carousel_on_mobile": false,
        "columns": 4,
        "mobile_columns": "2",
        "columns_gap": 8,
        "rows_gap": 24,
        "icons_style": "arrow",
        "icons_shape": "none",
        "section_width": "page-width",
        "gap": 28,
        "color_scheme": "scheme-1",
        "padding-block-start": 48,
        "padding-block-end": 48
      },
      "blocks": {
        "static-header": {
          "type": "_product-list-content",
          "name": "t:names.header",
          "static": true,
          "settings": {
            "content_direction": "row",
            "vertical_on_mobile": false,
            "horizontal_alignment": "space-between",
            "vertical_alignment": "flex-end",
            "align_baseline": true,
            "horizontal_alignment_flex_direction_column": "flex-start",
            "vertical_alignment_flex_direction_column": "center",
            "gap": 12,
            "width": "fill",
            "custom_width": 100,
            "width_mobile": "fill",
            "custom_width_mobile": 100,
            "height": "fit",
            "custom_height": 100,
            "inherit_color_scheme": true,
            "color_scheme": "",
            "background_media": "none",
            "video_position": "cover",
            "background_image_position": "cover",
            "border": "none",
            "border_width": 1,
            "border_opacity": 100,
            "border_radius": 0,
            "padding-block-start": 0,
            "padding-block-end": 0,
            "padding-inline-start": 0,
            "padding-inline-end": 0
          },
          "blocks": {
            "product_list_text": {
              "type": "_product-list-text",
              "name": "t:names.collection_title",
              "settings": {
                "text": "<h3>{{ closest.collection.title }}</h3>",
                "type_preset": "rte",
                "font": "var(--font-body--family)",
                "font_size": "",
                "line_height": "normal",
                "letter_spacing": "normal",
                "case": "none",
                "wrap": "pretty",
                "width": "fit-content",
                "max_width": "normal",
                "alignment": "left",
                "padding-block-start": 0,
                "padding-block-end": 0,
                "padding-inline-start": 0,
                "padding-inline-end": 0
              }
            },
            "product_list_button": {
              "type": "_product-list-button",
              "name": "t:names.product_list_button",
              "settings": {
                "label": "t:text_defaults.view_all_button_label",
                "open_in_new_tab": false,
                "style_class": "link",
                "width": "fit-content",
                "custom_width": 100,
                "width_mobile": "fit-content",
                "custom_width_mobile": 100
              }
            }
          },
          "block_order": ["product_list_text", "product_list_button"]
        },
        "static-product-card": {
          "type": "_product-card",
          "name": "t:names.product_card",
          "static": true,
