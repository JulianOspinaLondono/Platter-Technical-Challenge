{% assign product = closest.product %}

{% capture children %}
  {% unless product == blank %}
    <div
      class="product-badges product-badges--{{ settings.badge_position }}"
      style="
        --badge-border-radius: {{ settings.badge_corner_radius }}px;
        --badge-font-family: var(--font-{{ settings.badge_font_family }}--family); --badge-font-weight: var(--font-{{ settings.badge_font_family }}--weight); --badge-text-transform: {{ settings.badge_text_transform }};
      "
    >
      {%- comment -%} Native badges: sold out & sale {%- endcomment -%}
      {%- if product.available == false or product.compare_at_price > product.price -%}
        <div
          class="
            product-badges__badge product-badges__badge--rectangle
            {% if product.available == false %} color-{{ settings.badge_sold_out_color_scheme }}{% elsif product.compare_at_price > product.price %} color-{{ settings.badge_sale_color_scheme }}{% endif %}
          "
        >
          {%- if product.available == false -%}
            {{ 'content.product_badge_sold_out' | t }}
          {%- elsif product.compare_at_price > product.price -%}
            {{ 'content.product_badge_sale' | t }}
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- comment -%}
        Tag-based badges: add tags with prefix "badge:" to products.
        Examples: badge:best-seller, badge:save-15, badge:new, badge:limited
      {%- endcomment -%}
      {%- for tag in product.tags -%}
        {%- assign tag_lower = tag | downcase -%}
        {%- if tag_lower contains 'badge:' -%}
          {%- assign badge_value = tag | split: ':' | last | strip -%}
          {%- assign badge_value_lower = badge_value | downcase -%}

          {%- liquid
            assign badge_label = badge_value | replace: '-', ' '
            assign badge_modifier = 'custom'

            if badge_value_lower == 'best-seller' or badge_value_lower == 'best seller'
              assign badge_modifier = 'best-seller'
            elsif badge_value_lower contains 'save'
              assign badge_modifier = 'save'
            elsif badge_value_lower == 'new'
              assign badge_modifier = 'new'
            elsif badge_value_lower == 'limited'
              assign badge_modifier = 'limited'
            endif
          -%}

          <div class="product-badges__badge product-badges__badge--rectangle product-badges__badge--tag product-badges__badge--{{ badge_modifier }}">
            {{- badge_label -}}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
    {%  if settings.quick_add or settings.mobile_quick_add %}
      {% render 'quick-add', product: product, section_id: section.id %}
    {% endif %}
  {% endunless %}
{% endcapture %}

{% render 'card-gallery', children: children %}

{% # Title and price for the zoomed out grid view %}
<div class="product-grid-view-zoom-out--details">
  {% if product == blank %}
    <h3 class="h4">{{ 'content.product_card_placeholder' | t }}</h3>
  {% else %}
    <h3 class="h4">{{ product.title }}</h3>
  {% endif %}
</div>

{% stylesheet %}
  .product-badges {
    position: absolute;
    z-index: var(--layer-flat);
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem;
    top: 0.5rem;
    left: 0.5rem;
  }

  .product-badges--bottom-left {
    top: auto;
    bottom: 0.5rem;
    left: 0.5rem;
  }

  .product-badges--top-left {
    top: 0.5rem;
    left: 0.5rem;
  }

  .product-badges--top-right {
    top: 0.5rem;
    left: auto;
    right: 0.5rem;
  }

  .product-badges__badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: var(--color-foreground);
    background: var(--color-background);
    font-family: var(--font-h4--family);
    font-style: var(--font-h4--style);
    font-weight: var(--font-h4--weight);
    font-size: clamp(0.5rem, 1.2vw, 0.65rem);
    text-transform: var(--badge-text-transform);
    border: 0.0625rem solid #000000;
    border-radius: 6.25rem;
    padding: 0.25rem 0.5rem;
    line-height: 1;
    white-space: nowrap;
  }

  .product-badges__badge--rectangle {
    padding: 0.25rem 0.5rem;
  }

  /* Tag-based badge variants */
  .product-badges__badge--tag {
    text-transform: var(--badge-text-transform, uppercase);
  }

  .product-badges__badge--best-seller {
    background: var(--badge-best-seller-bg, #1a1a1a);
    color: var(--badge-best-seller-color, #ffffff);
  }

  .product-badges__badge--save {
    background: var(--badge-save-bg, #2d6b3f);
    color: var(--badge-save-color, #ffffff);
  }

  .product-badges__badge--new {
    background: var(--badge-new-bg, #0057b8);
    color: var(--badge-new-color, #ffffff);
  }

  .product-badges__badge--limited {
    background: var(--badge-limited-bg, #8b5e3c);
    color: var(--badge-limited-color, #ffffff);
  }

  .product-badges__badge--custom {
    background: var(--badge-custom-bg, #1a1a1a);
    color: var(--badge-custom-color, #ffffff);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.product_image",
  "tag": null,
  "settings": [
    {
      "type": "paragraph",
      "content": "t:content.resource_reference_product_media"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        {
          "value": "adapt",
          "label": "t:options.auto"
        },
        {
          "value": "portrait",
          "label": "t:options.portrait"
        },
        {
          "value": "square",
          "label": "t:options.square"
        },
        {
          "value": "landscape",
          "label": "t:options.landscape"
        }
      ],
      "default": "portrait",
      "label": "t:settings.aspect_ratio",
      "info": "t:info.aspect_ratio_adjusted"
    },
    {
      "type": "header",
      "content": "t:content.borders"
    },
    {
      "type": "select",
      "id": "border",
      "label": "t:settings.style",
      "options": [
        {
          "value": "none",
          "label": "t:options.none"
        },
        {
          "value": "solid",
          "label": "t:options.solid"
        }
      ],
      "default": "none"
    },
    {
      "type": "range",
      "id": "border_width",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "t:settings.thickness",
      "default": 1,
      "visible_if": "{{ block.settings.border != 'none' }}"
    },
    {
      "type": "range",
      "id": "border_opacity",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "t:settings.opacity",
      "default": 100,
      "visible_if": "{{ block.settings.border != 'none' }}"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "t:settings.border_radius",
      "min": 0,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "t:settings.left",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "t:settings.right",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "t:names.product_card_media",
      "category": "t:categories.product"
    }
  ]
}
{% endschema %}
