{%- doc -%}
  Best Sellers product card snippet.
  Renders a product card with tag-based badges, image hover swap, star ratings, and price.

  Badge system: add tags to products with the prefix "badge:"
    - badge:best-seller  → "BEST SELLER" (dark)
    - badge:save-15      → "SAVE 15%" (green)
    - badge:save-20      → "SAVE 20%" (green)
    - badge:new           → "NEW" (blue)
    - badge:limited       → "LIMITED" (brown)
    - badge:any-text      → renders "ANY TEXT" (dark fallback)

  @param {object} product - The product object (can be blank for placeholders)
  @param {boolean} show_reviews - Whether to show star reviews
  @param {string} review_count - Review count text
  @param {number} review_stars - Star rating (1-5, supports .5)
  @param {number} index - Product index in the loop
  @param {string} section_id - Parent section ID
{%- enddoc -%}

{%- liquid
  assign show_reviews = show_reviews | default: true
  assign review_count = review_count | default: '1,234 Reviews'
  assign review_stars = review_stars | default: 4.5
-%}

{%- if product != blank -%}
  <a href="{{ product.url }}" class="best-sellers__card" aria-label="{{ product.title }}">
    {%- comment -%} Image container with hover swap {%- endcomment -%}
    <div class="best-sellers__card-media">
      {%- comment -%} Badges from tags {%- endcomment -%}
      {%- assign badge_tags = '' -%}
      {%- for tag in product.tags -%}
        {%- assign tag_lower = tag | downcase -%}
        {%- if tag_lower contains 'badge:' -%}
          {%- assign badge_value = tag_lower | remove: 'badge:' | strip -%}
          {%- if badge_tags == '' -%}
            {%- assign badge_tags = badge_value -%}
          {%- else -%}
            {%- assign badge_tags = badge_tags | append: ',' | append: badge_value -%}
          {%- endif -%}
        {%- endif -%}
      {%- endfor -%}

      {%- if badge_tags != '' -%}
        <div class="best-sellers__badges">
          {%- assign badges_array = badge_tags | split: ',' -%}
          {%- for badge in badges_array -%}
            {%- liquid
              assign badge_class = 'best-sellers__badge--custom'
              assign badge_label = badge | replace: '-', ' ' | upcase

              if badge == 'best-seller'
                assign badge_class = 'best-sellers__badge--best-seller'
                assign badge_label = 'Best Seller'
              elsif badge contains 'save'
                assign badge_class = 'best-sellers__badge--save'
                assign save_amount = badge | remove: 'save-' | append: '%'
                assign badge_label = 'Save ' | append: save_amount
              elsif badge == 'new'
                assign badge_class = 'best-sellers__badge--new'
                assign badge_label = 'New'
              elsif badge == 'limited'
                assign badge_class = 'best-sellers__badge--limited'
                assign badge_label = 'Limited'
              endif
            -%}
            <span class="best-sellers__badge {{ badge_class }}">
              {{- badge_label -}}
            </span>
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- comment -%} Primary image {%- endcomment -%}
      {%- if product.featured_image != blank -%}
        <img
          src="{{ product.featured_image | image_url: width: 600 }}"
          alt="{{ product.featured_image.alt | escape | default: product.title | escape }}"
          width="{{ product.featured_image.width }}"
          height="{{ product.featured_image.height }}"
          loading="{% if index <= 5 %}eager{% else %}lazy{% endif %}"
          class="best-sellers__img--primary"
        >
      {%- else -%}
        <div class="best-sellers__card-media--placeholder">
          {{ 'product-apparel-1' | placeholder_svg_tag }}
        </div>
      {%- endif -%}

      {%- comment -%} Secondary image for hover {%- endcomment -%}
      {%- if product.images.size > 1 -%}
        <img
          src="{{ product.images[1] | image_url: width: 600 }}"
          alt="{{ product.images[1].alt | escape | default: product.title | escape }}"
          width="{{ product.images[1].width }}"
          height="{{ product.images[1].height }}"
          loading="lazy"
          class="best-sellers__img--secondary"
        >
      {%- endif -%}
    </div>

    {%- comment -%} Card info {%- endcomment -%}
    <div class="best-sellers__card-info">
      <h3 class="best-sellers__card-title">{{ product.title }}</h3>

      {%- if show_reviews -%}
        <div class="best-sellers__reviews" aria-label="{{ review_stars }} out of 5 stars, {{ review_count }}">
          <div class="best-sellers__stars" aria-hidden="true">
            {%- assign full_stars = review_stars | floor -%}
            {%- assign has_half = false -%}
            {%- assign star_remainder = review_stars | modulo: 1 -%}
            {%- if star_remainder > 0 -%}
              {%- assign has_half = true -%}
            {%- endif -%}

            {%- for i in (1..5) -%}
              {%- if i <= full_stars -%}
                <svg class="best-sellers__star" viewBox="0 0 20 20" fill="currentColor"><path d="M10 15.27L16.18 19l-1.64-7.03L20 7.24l-7.19-.61L10 0 7.19 6.63 0 7.24l5.46 4.73L3.82 19z"/></svg>
              {%- elsif has_half and i == full_stars | plus: 1 -%}
                <svg class="best-sellers__star" viewBox="0 0 20 20"><defs><linearGradient id="half-star-{{ section_id }}-{{ index }}"><stop offset="50%" stop-color="currentColor"/><stop offset="50%" stop-color="#ccc"/></linearGradient></defs><path d="M10 15.27L16.18 19l-1.64-7.03L20 7.24l-7.19-.61L10 0 7.19 6.63 0 7.24l5.46 4.73L3.82 19z" fill="url(#half-star-{{ section_id }}-{{ index }})"/></svg>
              {%- else -%}
                <svg class="best-sellers__star" viewBox="0 0 20 20" fill="#ccc"><path d="M10 15.27L16.18 19l-1.64-7.03L20 7.24l-7.19-.61L10 0 7.19 6.63 0 7.24l5.46 4.73L3.82 19z"/></svg>
              {%- endif -%}
            {%- endfor -%}
          </div>
          <span class="best-sellers__review-count">{{ review_count }}</span>
        </div>
      {%- endif -%}

      <div class="best-sellers__price">
        <span>{{ product.price | money }}</span>
        {%- if product.compare_at_price > product.price -%}
          <span class="best-sellers__price--compare">{{ product.compare_at_price | money }}</span>
        {%- endif -%}
      </div>
    </div>
  </a>

{%- else -%}
  {%- comment -%} Placeholder card {%- endcomment -%}
  <div class="best-sellers__card">
    <div class="best-sellers__card-media best-sellers__card-media--placeholder">
      {{ 'product-apparel-1' | placeholder_svg_tag }}
    </div>
    <div class="best-sellers__card-info">
      <h3 class="best-sellers__card-title">{{ 'content.product_card_placeholder' | t }}</h3>
      {%- if show_reviews -%}
        <div class="best-sellers__reviews">
          <div class="best-sellers__stars" aria-hidden="true">
            {%- for i in (1..5) -%}
              <svg class="best-sellers__star" viewBox="0 0 20 20" fill="#ccc"><path d="M10 15.27L16.18 19l-1.64-7.03L20 7.24l-7.19-.61L10 0 7.19 6.63 0 7.24l5.46 4.73L3.82 19z"/></svg>
            {%- endfor -%}
          </div>
          <span class="best-sellers__review-count">{{ review_count }}</span>
        </div>
      {%- endif -%}
      <div class="best-sellers__price">
        <span>{{ 1999 | money }}</span>
      </div>
    </div>
  </div>
{%- endif -%}
